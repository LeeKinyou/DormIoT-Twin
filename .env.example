# DormIoT-Twin 环境变量配置
# 复制此文件为 .env 并修改对应值

# ── 仿真 ──
DORMIOT_SIMULATION_NODE_COUNT=6
DORMIOT_SIMULATION_REPORT_INTERVAL_MS=1000

# ── 规则引擎阈值 ──
DORMIOT_POWER_THRESHOLD_ILLEGAL=1500.0
DORMIOT_POWER_THRESHOLD_OVERLOAD=800.0
DORMIOT_SMOKE_THRESHOLD_CRITICAL=0.40

# ── LLM（OpenAI 兼容格式） ──
DORMIOT_OPENAI_API_KEY=sk-your-api-key-here
DORMIOT_OPENAI_BASE_URL=https://api.openai.com/v1
DORMIOT_OPENAI_MODEL=gpt-4o-mini
