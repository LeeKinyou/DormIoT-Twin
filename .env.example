# DormIoT-Twin 环境变量配置
# 复制此文件为 .env 并修改对应值
# 密码中的特殊字符（如 @ : / 等）会自动 URL 编码，直接填写原始密码即可

# ── MQTT ──
DORMIOT_MQTT_BROKER_HOST=localhost
DORMIOT_MQTT_BROKER_PORT=1883
DORMIOT_MQTT_TOPIC_PATTERN=campus/+/+/meter

# ── Redis ──
DORMIOT_REDIS_HOST=localhost
DORMIOT_REDIS_PORT=6379
DORMIOT_REDIS_DB=0
DORMIOT_REDIS_PASSWORD=
DORMIOT_REDIS_USERNAME=

# ── MySQL ──
DORMIOT_MYSQL_HOST=localhost
DORMIOT_MYSQL_PORT=3306
DORMIOT_MYSQL_USER=root
DORMIOT_MYSQL_PASSWORD=your_password_here
DORMIOT_MYSQL_DATABASE=dormiot

# ── 仿真 ──
DORMIOT_SIMULATION_NODE_COUNT=50
DORMIOT_SIMULATION_REPORT_INTERVAL_MS=1000

# ── 规则引擎阈值 ──
DORMIOT_POWER_THRESHOLD_ILLEGAL=1500.0
DORMIOT_POWER_THRESHOLD_OVERLOAD=800.0
DORMIOT_SMOKE_THRESHOLD_CRITICAL=0.40
